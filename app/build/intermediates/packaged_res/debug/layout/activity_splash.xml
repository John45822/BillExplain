<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_login_hero"
    android:gravity="center" android:orientation="vertical">

    <!-- App icon — rounded square matching the login screen -->
    <LinearLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_splash_icon"
        android:gravity="center"
        android:elevation="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="46sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BillExplain"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="20dp"
        android:letterSpacing="0.02"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your smart electric bill companion"
        android:textSize="13sp"
        android:textColor="#B3FFFFFF"
        android:layout_marginTop="6dp"/>

</LinearLayout>