<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activities.MainActivity">

    <!-- Scrollable content -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:overScrollMode="never">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="20dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="20dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tvGreeting" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Good morning"
                        android:textSize="13sp" android:textColor="@color/gray_500"/>
                    <TextView android:id="@+id/tvUserName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Maria Santos"
                        android:textSize="18sp" android:textStyle="bold"
                        android:textColor="@color/gray_900" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvAvatar" android:layout_width="40dp"
                    android:layout_height="40dp" android:background="@drawable/bg_avatar"
                    android:text="M" android:textColor="@color/white" android:textSize="16sp"
                    android:textStyle="bold" android:gravity="center"/>
            </LinearLayout>

            <!-- Hero bill card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardHeroBill"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp" app:cardCornerRadius="28dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_bill" android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="THIS MONTH" android:textSize="11sp"
                        android:textColor="#B3FFFFFF" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/tvHeroAmount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₱3,250"
                        android:textSize="38sp" android:textStyle="bold"
                        android:textColor="@color/white" android:layout_marginTop="4dp"/>
                    <TextView android:id="@+id/tvHeroBillVs" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="vs ₱2,890 last month ↑12.5%"
                        android:textSize="12sp" android:textColor="#B3FFFFFF"/>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="horizontal"
                        android:layout_marginTop="14dp" android:gravity="center_vertical">
                        <TextView android:id="@+id/tvDueTag" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="⚡ Due in 2 days"
                            android:background="@drawable/bg_hero_tag" android:textColor="@color/white"
                            android:textSize="11sp" android:textStyle="bold"
                            android:paddingHorizontal="12dp" android:paddingVertical="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Premium Banner -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Upgrade Your Plan" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/gray_900"
                android:layout_marginStart="20dp" android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout android:id="@+id/cardPremiumBanner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_premium_banner"
                android:orientation="horizontal" android:padding="18dp"
                android:layout_marginHorizontal="20dp" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="46dp" android:layout_height="46dp"
                    android:background="#26FFFFFF" android:gravity="center"
                    android:layout_marginEnd="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="★" android:textSize="22sp" android:textColor="#FDE68A"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Get BillExplain Premium"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#FDE68A"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="AI chat + spending analytics unlock"
                        android:textSize="12sp" android:textColor="#B3FDE68A" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Recent Bills -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Recent Bills" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/gray_900"
                android:layout_marginStart="20dp" android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="16dp" app:cardElevation="2dp"
                app:strokeColor="@color/gray_100" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingHorizontal="16dp">

                    <include android:id="@+id/layoutBill1" layout="@layout/item_bill_row"/>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/gray_100"/>
                    <include android:id="@+id/layoutBill2" layout="@layout/item_bill_row"/>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/gray_100"/>
                    <include android:id="@+id/layoutBill3" layout="@layout/item_bill_row"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/white"
        android:elevation="8dp" android:paddingTop="12dp" android:paddingBottom="20dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="24dp" android:layout_height="24dp"
                android:text="⌂" android:textSize="20sp" android:textColor="@color/blue"
                android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="11sp" android:textColor="@color/blue"
                android:textStyle="bold" android:gravity="center" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navHistory" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="24dp" android:layout_height="24dp"
                android:text="☰" android:textSize="20sp" android:textColor="@color/gray_400"
                android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" android:textSize="11sp" android:textColor="@color/gray_400"
                android:gravity="center" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navPay" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/icon_payment"
                android:scaleType="centerInside"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pay" android:textSize="11sp" android:textColor="@color/gray_400"
                android:gravity="center" android:layout_marginTop="3dp"/>
        </LinearLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1">
            <LinearLayout android:id="@+id/navAi" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:gravity="center" android:padding="8dp"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/icon_ai_chat"
                    android:scaleType="centerInside"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AI" android:textSize="11sp" android:textColor="@color/gray_400"
                    android:gravity="center" android:layout_marginTop="3dp"/>
            </LinearLayout>
            <TextView android:id="@+id/ivAiLock" android:layout_width="16dp"
                android:layout_height="16dp" android:background="@drawable/bg_round_gold"
                android:text="🔒" android:textSize="7sp" android:gravity="center"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginStart="18dp" android:layout_marginTop="2dp"/>
        </FrameLayout>

        <LinearLayout android:id="@+id/navSettings" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="24dp" android:layout_height="24dp"
                android:text="⚙" android:textSize="20sp" android:textColor="@color/gray_400"
                android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textSize="11sp" android:textColor="@color/gray_400"
                android:gravity="center" android:layout_marginTop="5dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
