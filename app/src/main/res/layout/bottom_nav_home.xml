<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@color/white"
    android:elevation="8dp"
    android:paddingTop="12dp" android:paddingBottom="20dp">

    <!-- Home -->
    <LinearLayout android:id="@+id/navHome" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⌂" android:textSize="22sp" android:textColor="@color/blue"
            android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Home" android:textSize="11sp" android:textColor="@color/blue"
            android:textStyle="bold" android:gravity="center"/>
    </LinearLayout>

    <!-- History -->
    <LinearLayout android:id="@+id/navHistory" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="☰" android:textSize="20sp" android:textColor="@color/gray_400"
            android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="History"/>
    </LinearLayout>

    <!-- Pay -->
    <LinearLayout android:id="@+id/navPay" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💳" android:textSize="20sp" android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Pay"/>
    </LinearLayout>

    <!-- AI (with lock badge) -->
    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1">
        <LinearLayout android:id="@+id/navAi" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="center" android:padding="8dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🤖" android:textSize="20sp" android:gravity="center"/>
            <TextView style="@style/NavText" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="AI"/>
        </LinearLayout>
        <TextView android:id="@+id/ivAiLock" android:layout_width="16dp"
            android:layout_height="16dp" android:background="@drawable/bg_round_gold"
            android:text="🔒" android:textSize="7sp" android:gravity="center"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginStart="18dp" android:layout_marginTop="2dp"/>
    </FrameLayout>

    <!-- Settings -->
    <LinearLayout android:id="@+id/navSettings" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙" android:textSize="20sp" android:textColor="@color/gray_400"
            android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Settings"/>
    </LinearLayout>

</LinearLayout>
