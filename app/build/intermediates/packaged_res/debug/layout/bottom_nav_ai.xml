<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@color/white"
    android:elevation="8dp" android:paddingTop="12dp" android:paddingBottom="20dp">

    <LinearLayout android:id="@+id/navHome" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⌂" android:textSize="22sp" android:textColor="@color/gray_400" android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navHistory" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="☰" android:textSize="20sp" android:textColor="@color/gray_400" android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navPay" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💳" android:textSize="20sp" android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pay"/>
    </LinearLayout>

    <!-- AI — active -->
    <LinearLayout android:id="@+id/navAi" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🤖" android:textSize="20sp" android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AI" android:textSize="11sp" android:textColor="@color/blue"
            android:textStyle="bold" android:gravity="center"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/navSettings" style="@style/NavItem"
        android:clickable="true" android:focusable="true">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙" android:textSize="20sp" android:textColor="@color/gray_400" android:gravity="center"/>
        <TextView style="@style/NavText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings"/>
    </LinearLayout>
</LinearLayout>
