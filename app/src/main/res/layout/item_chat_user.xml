<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="end"
    android:paddingVertical="4dp">

    <TextView android:id="@+id/tvMessage"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:background="@drawable/bg_chat_user"
        android:text="User message" android:textSize="14sp"
        android:textColor="@color/white" android:lineSpacingMultiplier="1.4"
        android:paddingHorizontal="14dp" android:paddingVertical="11dp"/>
</LinearLayout>
