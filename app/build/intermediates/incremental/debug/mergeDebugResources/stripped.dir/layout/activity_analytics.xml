<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activities.AnalyticsActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:overScrollMode="never">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="← Back" android:textColor="@color/blue"
                android:backgroundTint="@color/transparent" android:textSize="14sp"
                android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Spending Analytics" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/gray_900" android:layout_marginBottom="16dp"/>

            <!-- Chart toggle -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/bg_chart_toggle" android:orientation="horizontal"
                android:padding="3dp" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/btnBar" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="Bar Chart" android:gravity="center"
                    android:textSize="13sp" android:textStyle="bold" android:textColor="@color/blue"
                    android:background="@drawable/bg_chart_btn_active"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btnLine" android:layout_width="0dp"
                    android:layout_height="match_parent" android:layout_weight="1"
                    android:text="Line Graph" android:gravity="center"
                    android:textSize="13sp" android:textStyle="bold" android:textColor="@color/gray_500"
                    android:background="@android:color/transparent"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Chart card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="2dp" app:strokeColor="@color/gray_100" app:strokeWidth="1dp"
                android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Monthly Bill – Last 6 Months"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/gray_600" android:layout_marginBottom="12dp"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent" android:layout_height="200dp"
                        android:visibility="visible"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent" android:layout_height="200dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_total_card"
                    android:orientation="vertical" android:gravity="center"
                    android:padding="12dp" android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvStatHigh" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₱3,250"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="@color/red"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Highest" android:textSize="11sp" android:textColor="@color/gray_500"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_total_card"
                    android:orientation="vertical" android:gravity="center"
                    android:padding="12dp" android:layout_marginHorizontal="5dp">
                    <TextView android:id="@+id/tvStatLow" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₱2,540"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="@color/green"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lowest" android:textSize="11sp" android:textColor="@color/gray_500"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:background="@drawable/bg_total_card"
                    android:orientation="vertical" android:gravity="center"
                    android:padding="12dp" android:layout_marginStart="5dp">
                    <TextView android:id="@+id/tvStatMoM" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="+12.5%"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="@color/red"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MoM Change" android:textSize="11sp" android:textColor="@color/gray_500"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Insights -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Insights" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/gray_900" android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="2dp" app:strokeColor="@color/gray_100" app:strokeWidth="1dp"
                android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="top">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌡️" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Summer spike detected" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/gray_900"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bills rise Mar–May due to AC usage. Set AC to 26°C to save ~₱150/month."
                            android:textSize="12sp" android:textColor="@color/gray_500"
                            android:layout_marginTop="3dp" android:lineSpacingMultiplier="1.3"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="2dp" app:strokeColor="@color/gray_100" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="top">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Potential savings: ₱400/month" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/gray_900"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Switch to LED bulbs, unplug idle devices, and use a timer on water heater."
                            android:textSize="12sp" android:textColor="@color/gray_500"
                            android:layout_marginTop="3dp" android:lineSpacingMultiplier="1.3"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
