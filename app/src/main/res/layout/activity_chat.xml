<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activities.ChatActivity">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp"
        android:paddingBottom="8dp" android:elevation="2dp" android:background="@color/white">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← BillExplain AI" android:textColor="@color/blue"
            android:backgroundTint="@color/transparent" android:textSize="14sp"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chat" android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/gray_900"/>
    </LinearLayout>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvChat"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:paddingHorizontal="20dp"
        android:paddingTop="12dp" android:paddingBottom="4dp"
        android:clipToPadding="false" android:overScrollMode="never"/>

    <!-- Suggestion chips -->
    <HorizontalScrollView android:id="@+id/scrollSuggestions"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:paddingHorizontal="20dp" android:paddingBottom="8dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/chipWhy" android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why is it so high?"
                android:background="@drawable/bg_chip_suggestion"
                android:textColor="@color/blue" android:textSize="13sp"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chipReduce" android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show me how to reduce consumption"
                android:background="@drawable/bg_chip_suggestion"
                android:textColor="@color/blue" android:textSize="13sp"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chipGeneration" android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What is generation charge?"
                android:background="@drawable/bg_chip_suggestion"
                android:textColor="@color/blue" android:textSize="13sp"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/gray_100"/>

    <!-- Input row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp"
        android:paddingBottom="24dp" android:gravity="center_vertical">
        <EditText android:id="@+id/etChat" android:layout_width="0dp"
            android:layout_height="46dp" android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="Ask me anything..." android:paddingHorizontal="16dp"
            android:textSize="14sp" android:inputType="text"
            android:maxLines="1" android:imeOptions="actionSend"
            android:layout_marginEnd="10dp"/>
        <LinearLayout android:id="@+id/btnSend" android:layout_width="42dp"
            android:layout_height="42dp" android:background="@drawable/bg_round_blue"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="➤" android:textSize="16sp" android:textColor="@color/white"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
