<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activities.PaymentActivity">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:overScrollMode="never">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="← Back" android:textColor="@color/blue"
                android:backgroundTint="@color/transparent" android:textSize="14sp"
                android:layout_marginBottom="4dp"
                app:strokeWidth="0dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Payment" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/gray_900" android:layout_marginBottom="16dp"/>

            <!-- Amount card with QR -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardCornerRadius="16dp"
                app:cardElevation="2dp" app:strokeColor="@color/gray_200" app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="16dp">
                    <TextView android:id="@+id/tvProvider" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CEPALCO"
                        android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/gray_900" android:layout_marginBottom="2dp"/>
                    <TextView android:id="@+id/tvRef" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Ref: BE-042026-001"
                        android:textSize="12sp" android:textColor="@color/gray_400"/>
                    <!-- QR placeholder -->
                    <LinearLayout android:layout_width="140dp" android:layout_height="140dp"
                        android:background="@drawable/bg_qr" android:gravity="center"
                        android:layout_marginVertical="10dp" android:padding="8dp">
                        <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                            android:src="@drawable/ic_qr_code"
                            android:scaleType="fitCenter"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Scan to pay via InstaPay" android:textSize="11sp"
                        android:textColor="@color/gray_400"/>
                    <TextView android:id="@+id/tvPayAmount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₱3,250"
                        android:textSize="28sp" android:textStyle="bold"
                        android:textColor="@color/gray_900" android:layout_marginTop="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bank Cards -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BANK CARDS" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/gray_500" android:letterSpacing="0.07"
                android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/chipBpi" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="BPI" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_default"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/chipLandbank" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Landbank" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_default"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/chipUnionbank" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="UnionBank" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_default"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- E-Wallets -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="E-WALLETS" android:textSize="12sp" android:textStyle="bold"
                android:textColor="@color/gray_500" android:letterSpacing="0.07"
                android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="24dp">
                <TextView android:id="@+id/chipMaya" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Maya" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_default"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/chipGcash" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="GCash" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_selected"
                    android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/chipPaypal" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="PayPal" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="@color/gray_800" android:gravity="center"
                    android:padding="10dp" android:background="@drawable/chip_default"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmPay" style="@style/BtnPrimary"
                android:text="Confirm &amp; Pay"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
